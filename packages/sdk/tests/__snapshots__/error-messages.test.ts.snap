// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`error messages > InvalidInputError > bad address includes truncated input 1`] = `"Invalid account address: "GABC""`;

exports[`error messages > InvalidInputError > bad hash includes truncated input 1`] = `"Invalid transaction hash: "abc123""`;

exports[`error messages > NetworkError 1`] = `"Network error"`;

exports[`error messages > NotFoundError 1`] = `"Resource not found"`;

exports[`error messages > RateLimitError > with retryAfter 1`] = `"Rate limit exceeded"`;

exports[`error messages > RateLimitError > without retryAfter 1`] = `"Rate limit exceeded"`;

exports[`error messages > TimeoutError 1`] = `"Request timed out"`;

exports[`error messages > UpstreamError 1`] = `"Upstream error"`;
