{
  "name": "@stellar-explain/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Stellar Explain API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/undiciFetch": {
      "import": "./dist/adapters/undiciFetch.js",
      "types": "./dist/adapters/undiciFetch.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "undici": ">=5"
  },
  "peerDependenciesMeta": {
    "undici": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5",
    "undici": "^6"
  }
}
