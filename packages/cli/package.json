{
  "name": "@stellar-explain/cli",
  "version": "0.1.0",
  "description": "CLI for the Stellar Explain API",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "stellar-explain": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "5.3.0",
    "commander": "12.1.0",
    "ora": "8.1.1"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "typescript": "5.4.5"
  }
}
